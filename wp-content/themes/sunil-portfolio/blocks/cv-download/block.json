{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "sunil-portfolio/cv-download",
    "title": "CV Download / CTA",
    "description": "A full-width CTA banner with a heading, subtext, and two action buttons.",
    "category": "theme",
    "icon": "download",
    "supports": {
        "html": false,
        "color": {
            "text": true,
            "background": true,
            "gradients": true,
            "link": true
        },
        "typography": {
            "fontSize": true,
            "lineHeight": true,
            "fontFamily": true,
            "fontWeight": true,
            "fontStyle": true,
            "letterSpacing": true,
            "textDecoration": true,
            "textTransform": true
        },
        "spacing": {
            "margin": true,
            "padding": true,
            "blockGap": true
        },
        "__experimentalBorder": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        }
    },
    "keywords": ["cta", "cv", "download", "contact", "call to action"],
    "attributes": {
        "heading": {
            "type": "string",
            "default": "Ready to build something exceptional?"
        },
        "headingHighlight": {
            "type": "string",
            "default": "exceptional?"
        },
        "subtext": {
            "type": "string",
            "default": "I'm currently accepting new projects for Q3 & Q4 2024. Let's discuss your architectural needs."
        },
        "primaryLabel": {
            "type": "string",
            "default": "Book a Consultation"
        },
        "primaryUrl": {
            "type": "string",
            "default": "#contact"
        },
        "secondaryLabel": {
            "type": "string",
            "default": "Download CV"
        },
        "secondaryUrl": {
            "type": "string",
            "default": "#"
        },
        "cvFile": {
            "type": "string",
            "default": ""
        }
    },
    "textdomain": "sunil-portfolio",
    "editorScript": "file:../../build/index.js",
    "render": "file:./render.php"
}