{
    "name": "sunil-portfolio",
    "version": "1.0.0",
    "scripts": {
        "build": "wp-scripts build src/index.js --output-path=build && npm run build:css",
        "start": "wp-scripts start src/index.js --output-path=build",
        "build:css": "tailwindcss -i ./assets/css/tailwind.css -o ./assets/css/main.css --minify"
    },
    "devDependencies": {
        "@wordpress/scripts": "^30.0.0",
        "tailwindcss": "3.4.1"
    }
}