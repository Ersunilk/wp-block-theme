{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "sunil-portfolio/contact-form",
    "title": "Contact Form",
    "category": "theme",
    "description": "Dynamic contact form with editable content",
    "supports": {
        "html": false,
        "color": {
            "text": true,
            "background": true,
            "gradients": true,
            "link": true
        },
        "typography": {
            "fontSize": true,
            "lineHeight": true,
            "fontFamily": true,
            "fontWeight": true,
            "fontStyle": true,
            "letterSpacing": true,
            "textDecoration": true,
            "textTransform": true
        },
        "spacing": {
            "margin": true,
            "padding": true,
            "blockGap": true
        },
        "__experimentalBorder": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        }
    },
    "attributes": {
        "heading": {
            "type": "string",
            "default": "Let's build extraordinary together."
        },
        "subheading": {
            "type": "string",
            "default": "Have a groundbreaking project in mind? I'm currently accepting new high-impact projects."
        },
        "email": {
            "type": "string",
            "default": "hello@sunilkumar.dev"
        },
        "phone": {
            "type": "string",
            "default": "+49 000 000 0000"
        },
        "location": {
            "type": "string",
            "default": "Berlin, Germany"
        },
        "buttonText": {
            "type": "string",
            "default": "Start a Project"
        },
        "linkedinUrl": {
            "type": "string",
            "default": "https://linkedin.com/in/sunilkumar"
        },
        "githubUrl": {
            "type": "string",
            "default": "https://github.com/Ersunilk"
        },
        "successMessage": {
            "type": "string",
            "default": "Thank you! I will get back to you within 24 hours."
        }
    },
    "textdomain": "sunil-portfolio",
    "editorScript": "file:../../build/index.js",
    "render": "file:./render.php"
}