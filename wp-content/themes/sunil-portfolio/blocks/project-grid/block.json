{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "sunil-portfolio/project-grid",
    "title": "Project Grid",
    "category": "theme",
    "description": "Portfolio projects slider fetched from CPT",
    "supports": { "html": false },
    "attributes": {
        "heading": {
            "type": "string",
            "default": "xxxxxxxx Work"
        },
        "subheading": {
            "type": "string",
            "default": "Engineered for Scale"
        },
        "postsCount": {
            "type": "number",
            "default": 6
        },
        "bgColor": {
            "type": "string",
            "default": "#fafafa"
        }
    },
    "textdomain": "sunil-portfolio",
    "editorScript": "file:../../build/index.js",
    "render": "file:./render.php"
}